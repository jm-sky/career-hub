        "$value": "#6b62f2",
        "$type": "color",
        "$description": "Dusk Violet — The only chromatic accent — used at 0.565 alpha in a horizontal gradient wash to add a single pulse of color to the dark UI; Radial glow accent — concentrated violet center fading to white, used as spotlight or product reveal moment"
      }
