    "font": {
      "dm-sans": {
        "$value": "DM Sans",
        "$type": "fontFamily",
        "$description": "Primary display and body face — used for the 72px hero headline (weight 500, -0.035em tracking) and all 16px body/UI text. The weight-500 display choice is anti-convention: most sites push 700+ for hero headlines, but DM Sans at 500 with tight tracking achieves authority through restraint and modernity through geometric clarity."
      },
      "geist": {
        "$value": "Geist",
        "$type": "fontFamily",
        "$description": "Secondary face for feature headings and editorial body — Geist's mono-adjacent precision adds a technical, product-aware texture to section headings (32px/600, 36px/500, 48px/500). The 24px body usage in Geist creates a slightly more compressed, information-dense reading rhythm compared to DM Sans."
      },
      "system-ui": {
