{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Catalogue Items",
  "description": "Schema for catalogue items seeder data",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "name", "category", "brand", "model"],
    "properties": {
      "id": {
        "type": "string",
        "description": "Unique identifier for the catalogue item"
      },
      "name": {
        "type": "string",
        "description": "Product name"
      },
      "category": {
        "type": "string",
        "enum": ["water", "food", "shelter", "fire", "firstAid", "blades", "tools", "light", "navigation", "communication", "clothing", "hygiene", "other"],
        "description": "Product category. Should match TGearItemCategory from frontend."
      },
      "brand": {
        "type": "string",
        "description": "Product brand"
      },
      "model": {
        "type": "string",
        "description": "Product model"
      },
      "description": {
        "type": "string",
        "description": "Product description"
      },
      "price_tier": {
        "type": "string",
        "enum": ["low", "medium", "high"],
        "description": "Price tier"
      },
      "quality": {
        "type": "string",
        "enum": ["low", "medium", "high"],
        "description": "Product quality"
      },
      "weight": {
        "type": "number",
        "description": "Product weight"
      },
      "weight_unit": {
        "type": "string",
        "enum": ["g", "kg", "oz", "lb"],
        "description": "Weight unit"
      },
      "url": {
        "type": "string",
        "format": "uri",
        "description": "Product URL"
      },
      "image_filename": {
        "type": "string",
        "description": "Product image filename"
      },
      "color": {
        "type": "string",
        "description": "Product color"
      },
      "shops": {
        "type": "array",
        "description": "List of shop URLs where the product is available",
        "items": {
          "type": "object",
          "required": ["url"],
          "properties": {
            "url": {
              "type": "string",
              "format": "uri",
              "description": "Shop product URL"
            },
            "variant": {
              "type": "string",
              "description": "Product variant (e.g., color, size)"
            },
            "price": {
              "type": "number",
              "description": "Product price"
            },
            "currency": {
              "type": "string",
              "description": "Price currency (e.g., USD, PLN)",
              "enum": ["USD", "PLN", "EUR", "GBP", "JPY", "CHF", "CAD", "AUD"]
            },
            "updated_at": {
              "type": "string",
              "format": "date",
              "description": "Date when the price was last updated (ISO date format: YYYY-MM-DD)"
            }
          },
          "additionalProperties": false
        }
      }
    },
    "additionalProperties": false
  }
}

