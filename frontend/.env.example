# Database Configuration
DB_USER=careerhub
DB_PASSWORD=careerhub_pass
DB_NAME=careerhub
DB_PORT=5432

# Redis Configuration
REDIS_PORT=6379

# MinIO Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Application Ports
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Backend Environment
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
ENVIRONMENT=development
DEBUG=true

# Frontend Environment
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_AI_FEATURES=false
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Auth Redirects (optional - defaults in auth-config.ts)
NEXT_PUBLIC_LOGIN_REDIRECT=/dashboard
NEXT_PUBLIC_LOGOUT_REDIRECT=/login
NEXT_PUBLIC_UNAUTHORIZED_REDIRECT=/login
NEXT_PUBLIC_REGISTER_REDIRECT=/dashboard

NEXT_PUBLIC_DEFAULT_USER_EMAIL=
NEXT_PUBLIC_DEFAULT_USER_PASSWORD=

# Google reCAPTCHA v3 (optional)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
NEXT_PUBLIC_RECAPTCHA_ENABLED=false

# Email (optional for development)
EMAIL_ENABLED=false
EMAIL_FROM=noreply@careerhub.com

# AI Services (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Monitoring (optional)
SENTRY_DSN=
